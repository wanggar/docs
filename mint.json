{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Wordship",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
  "primary": "#000000", // Pure black for a clean primary color
  "light": "#F5F5F5",   // Light gray for a soft background or accents
  "dark": "#333333",    // Dark gray for text or darker elements
  "anchors": {
    "from": "#666666",   // Mid-gray for gradient starting point
    "to": "#999999"      // Light gray for gradient endpoint
  }
 },
  "topbarLinks": [],
  "topbarCtaButton": {
    "name": "Start App",
    "url": "https://preview.wordship.ai"
  },
  "tabs": [],
  "anchors": [
    {
      "name": "Documentation",
      "icon": "book-open-cover",
      "url": "https://mintlify.com/docs"
    },
    {
      "name": "Community",
      "icon": "slack",
      "url": "https://mintlify.com/community"
    },
    {
      "name": "Blog",
      "icon": "newspaper",
      "url": "https://mintlify.com/blog"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": [
        "introduction",
        "quickstart",
        "development"
      ]
    },
    {
      "group": "Terms & Agreement",
      "pages": [
        "essentials/markdown",
        "essentials/code",
        "essentials/images",
        "essentials/settings",
        "essentials/navigation",
        "essentials/reusable-snippets",
        "essentials/terms-conditions",
        "essentials/privacy-agreement"
      ]
    },
    {
      "group": "API Documentation",
      "pages": [
        "api-reference/introduction"
      ]
    },
    {
      "group": "Endpoint Examples",
      "pages": [
        "api-reference/endpoint/get",
        "api-reference/endpoint/create",
        "api-reference/endpoint/delete"
      ]
    }
  ],
  "footerSocials": {
    "x": "https://x.com/mintlify",
    "github": "https://github.com/mintlify",
    "linkedin": "https://linkedin.com/company/mintlify"
  }
}
